{
  "name": "networth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "npm run db:push && next dev",
    "dev:random-port": "npm run db:push && next dev -p 0",
    "dev:check": "bash scripts/dev-check.sh",
    "build": "TURBO_NO_UPDATE_NOTIFIER=true turbo run _build --output-logs errors-only",
    "_build": "next build",
    "start": "npm run dev",
    "lint": "TURBO_NO_UPDATE_NOTIFIER=true turbo run _lint --output-logs errors-only",
    "_lint": "eslint",
    "test": "TURBO_NO_UPDATE_NOTIFIER=true turbo run _test --output-logs errors-only",
    "_test": "vitest run --reporter=dot",
    "_smoke": "bash scripts/smoke-test.sh",
    "test:coverage": "vitest run --coverage --coverage.skipFull",
    "verify": "TURBO_NO_UPDATE_NOTIFIER=true turbo run _lint _build _test _smoke --output-logs errors-only",
    "format": "eslint --fix src/",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "node scripts/seed.js",
    "setup": "npm install",
    "rebase": "git fetch origin main 2>/dev/null; git rebase origin/main 2>&1 || { git rebase --abort 2>/dev/null; echo 'Rebase onto origin/main failed. Please resolve conflicts and rebase.' >&2; exit 2; }"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^28.0.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "turbo": "^2.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  }
}
